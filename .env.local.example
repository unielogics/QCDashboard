CLERK_SECRET_KEY=

# ─── Agent Funding Command Center backend feature flags ────────────────────
# Flip these to "true" once the corresponding backend endpoints ship. While
# false, the relevant hooks use in-memory mocks so the UI is clean (no dev
# network noise) and Agents can demo end-to-end on the frontend alone.

# TODO(P0A backend): flip to true once GET /leads?scope=mine and POST /leads ship
NEXT_PUBLIC_BACKEND_HAS_LEADS=false

# TODO(P0A backend): flip to true once GET /deals?scope=mine and POST /deals ship
NEXT_PUBLIC_BACKEND_HAS_DEALS=false
